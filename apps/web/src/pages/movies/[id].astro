---
import Layout from "../../layouts/Layout.astro";
import MovieDetailsClient from "../../components/movies/MovieDetailsClient";
import { serverApi } from "../../lib/server-api";
import { Icon } from "@iconify/react";
import type { Movie } from "../../types/movie";

// CONCEPTO: Caché HTTP SSR en Rutas Dinámicas
// QUE HACE: Guarda el HTML generado del detalle de la película en memoria temporalmente.
// POR QUE LO USO: Hace que la View Transition al entrar a la película sea totalmente instantánea.
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, stale-while-revalidate=120",
);

// CONCEPTO: Rutas Dinamicas con Astro.params
// QUE HACE: Lee el parametro [id] de la URL para resolver la pelicula solicitada.
// POR QUE LO USO: Permite una sola plantilla reutilizable para todos los detalles de peliculas.
const { id } = Astro.params;

let movie: Movie | null = null;
let errorMessage = "";

try {
  // CONCEPTO: Guard Clause de Parametro
  // QUE HACE: Corta la ejecucion si falta el id en la URL.
  // POR QUE LO USO: Evita llamadas invalidas al backend y simplifica el control de errores.
  if (!id) {
    throw new Error("ID de pelicula no proporcionado");
  }

  // CONCEPTO: Carga de Datos en SSR
  // QUE HACE: Trae en servidor el detalle completo antes de pintar la pagina.
  // POR QUE LO USO: Mejora SEO y reduce parpadeos de contenido.
  const { data, error } = await serverApi.api.movies({ apiId: id }).get();
  if (error)
    throw new Error(
      typeof error.value === "string" ? error.value : "API no disponible",
    );
  movie = data as Movie;
} catch (error) {
  errorMessage =
    error instanceof Error
      ? error.message
      : "Ocurrio un error al cargar los detalles de la pelicula";
}
---

<Layout
  title={movie
    ? `${movie.title} - Detalles | Alexandria`
    : "Error | Alexandria"}
>
  <div class="mb-6">
    <a
      href="/movies"
      class="inline-flex items-center gap-2 text-sm text-slate dark:text-mist hover:text-ink dark:hover:text-screen transition-colors group"
    >
      <Icon
        icon="tabler:arrow-left"
        className="w-5 h-5 group-hover:-translate-x-0.5 transition-transform"
      />
      Volver a Películas
    </a>
  </div>
  {
    errorMessage || !movie ? (
      <div class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4">
        <div class="rounded-2xl border border-bone dark:border-night-edge bg-linen dark:bg-coal p-8 max-w-md w-full shadow-lg">
          <Icon
            icon="tabler:movie-off"
            className="mx-auto mb-4 h-16 w-16 text-slate opacity-50 dark:text-mist"
          />
          <h1 class="mb-2 text-2xl font-bold text-ink dark:text-screen">
            Película no encontrada
          </h1>
          <p class="mb-6 text-sm text-slate dark:text-mist">
            {errorMessage ||
              "No hemos podido encontrar los detalles de esta película. Puede que el enlace sea incorrecto o el servicio no esté disponible."}
          </p>
          <a
            href="/movies"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-ink px-5 py-3 text-sm font-semibold text-screen transition-all hover:scale-105 active:scale-95 dark:bg-screen dark:text-ink"
          >
            Volver al catálogo
          </a>
        </div>
      </div>
    ) : (
      // CONCEPTO: Hidratacion de Isla React
      // QUE HACE: Activa interacciones del detalle de pelicula en cliente.
      // POR QUE LO USO: Combina SSR inicial con UX interactiva.
      <MovieDetailsClient client:load movie={movie} />
    )
  }
</Layout>
