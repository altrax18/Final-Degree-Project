---
import Layout from "../../layouts/Layout.astro";
import MovieCatalogClient from "../../components/movies/MovieCatalogClient";
import { serverApi } from "../../lib/server-api";
import type { Movie } from "../../types/movie";

// CONCEPTO: Caché HTTP SSR (Stale-While-Revalidate)
// QUE HACE: Guarda el HTML generado en memoria temporalmente. Devuelve la página al instante.
// POR QUE LO USO: Es el patrón oficial para SSR pesado. Evita hacer llamadas lentas en cada recarga.
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, stale-while-revalidate=120",
);

// CONCEPTO: Estado Inicial Seguro en SSR
// QUE HACE: Inicializa datos antes de invocar la API.
// POR QUE LO USO: Permite renderizar mensaje de error sin romper la pagina.
let movies: {
  items: Movie[];
  total: number;
  page: number;
  perPage: number;
  totalPages: number;
  genres: string[];
} = {
  items: [],
  total: 0,
  page: 1,
  perPage: 20,
  totalPages: 1,
  genres: [],
};
let errorMessage = "";

try {
  const { data, error } = await serverApi.api.movies.get();
  if (error)
    throw new Error(
      typeof error.value === "string" ? error.value : "API no disponible",
    );
  movies = data as typeof movies;
} catch (error) {
  errorMessage =
    error instanceof Error
      ? error.message
      : "No se pudieron cargar las películas";
}
---

<Layout title="Explorar Películas - Alexandria">
  <main class="min-h-screen pt-8">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1
        class="text-4xl md:text-5xl font-extrabold text-ink dark:text-screen mb-8 tracking-tight"
      >
        Catálogo de <span class="text-sapphire dark:text-electric-sky"
          >Películas</span
        >
      </h1>
    </div>

    {
      errorMessage && (
        <div class="max-w-3xl mx-auto mt-8 p-4 rounded-xl border border-red-500/30 bg-red-500/10 text-red-400 text-center">
          <p>
            {errorMessage}. Verifica que apps/api este corriendo en el puerto
            3000 y que TMDB_BEARER_TOKEN o TMDB_API_KEY existan en tu .env.
          </p>
        </div>
      )
    }

    {
      /* CONCEPTO: Hidratacion de Islas (client:load)
         QUE HACE: Hidrata el componente React para habilitar busqueda y filtros.
         POR QUE LO USO: Sin hidratacion, la UI seria estatica y sin interaccion.*/
    }
    {!errorMessage && <MovieCatalogClient client:load initialMovies={movies} />}
  </main>
</Layout>
