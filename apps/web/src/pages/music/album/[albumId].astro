---
// src/pages/music/album/[albumId].astro
import Layout from "../../../layouts/Layout.astro";
import AlbumDetail from "../../../components/music/AlbumDetail.jsx";
import { serverApi } from "../../../lib/server-api";
import { Icon } from "@iconify/react";

const { albumId } = Astro.params;

let album: any = null;
let tracks: any[] = [];
let fetchError: string | null = null;

if (albumId) {
  const { data, error } = await (serverApi as any).api.music.album({ id: albumId }).get();
  if (error || !data) {
    fetchError =
      "No se pudo cargar el álbum. Comprueba que la API esté activa.";
  } else {
    album = (data as any).album ?? null;
    tracks = (data as any).tracks ?? [];
  }
}
---

<Layout title={album ? `${album.title} — Álbum` : "Álbum"}>
  <!-- Enlace de regreso -->
  <div class="mb-6">
    <a
      href="/music"
      class="inline-flex items-center gap-2 text-sm text-slate dark:text-mist hover:text-ink dark:hover:text-screen transition-colors group"
    >
      <Icon
        icon="tabler:arrow-left"
        className="w-5 h-5 group-hover:-translate-x-0.5 transition-transform"
      />
      Volver a Música
    </a>
  </div>

  <!-- Estado de error -->
  {
    fetchError && (
      <div class="rounded-xl border border-red-500/30 bg-red-500/10 px-5 py-4 text-red-400 text-sm flex items-center gap-3">
        <Icon icon="tabler:alert-circle" className="w-5 h-5" />
        {fetchError}
      </div>
    )
  }

  <!-- Detalle del álbum (isla de React) -->
  {album && <AlbumDetail client:only="react" album={album} tracks={tracks} />}

  <!-- No encontrado -->
  {
    !fetchError && !album && (
      <div class="flex flex-col items-center justify-center py-32 gap-4 text-slate dark:text-mist">
        <span class="text-6xl">💿</span>
        <p class="text-lg font-medium">Álbum no encontrado</p>
        <a
          href="/music"
          class="text-amethyst dark:text-orchid hover:text-amethyst/80 dark:hover:text-orchid/80 text-sm underline"
        >
          Volver a Música
        </a>
      </div>
    )
  }
</Layout>
