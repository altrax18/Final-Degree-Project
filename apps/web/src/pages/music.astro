---
import Layout from "../layouts/Layout.astro";
import MusicCatalogClient from "../components/music/MusicCatalogClient";
import { serverApi } from "../lib/server-api";

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, stale-while-revalidate=120",
);

let music: {
  items: any[];
  total: number;
  page: number;
  perPage: number;
  totalPages: number;
  genres: string[];
} = {
  items: [],
  total: 0,
  page: 1,
  perPage: 20,
  totalPages: 1,
  genres: [],
};
let errorMessage = "";

try {
  const { data, error } = await serverApi.api.music.get();
  if (error) {
    throw new Error(
      typeof error.value === "string" ? error.value : "API no disponible",
    );
  }
  music = data as typeof music;
} catch (error) {
  errorMessage =
    error instanceof Error
      ? error.message
      : "No se pudieron cargar las canciones";
}
---

<Layout title="Explorar Música - Alexandria">
  <main class="min-h-screen pt-8">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1
        class="text-4xl md:text-5xl font-extrabold text-ink dark:text-screen mb-8 tracking-tight"
      >
        Catálogo de <span class="text-sapphire dark:text-electric-sky"
          >Música</span
        >
      </h1>
    </div>

    {
      errorMessage && (
        <div class="max-w-3xl mx-auto mt-8 p-4 rounded-xl border border-red-500/30 bg-red-500/10 text-red-400 text-center">
          <p>
            {errorMessage}. Verifica que apps/api esté corriendo en el puerto
            3000.
          </p>
        </div>
      )
    }

    {!errorMessage && <MusicCatalogClient client:load initialMusic={music} />}
  </main>
</Layout>
