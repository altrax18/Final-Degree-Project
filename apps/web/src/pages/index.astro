---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import MediaCard from "../components/shared/MediaCard.jsx";
import { getTrending } from "../lib/api";

let trending: any[] = [];
let error = null;

try {
  // CONCEPTO: Programacion defensiva en SSR
  // QUE HACE: Garantiza que trending sea siempre un arreglo antes de renderizar con map.
  // POR QUE LO USO: Evita fallos de render cuando una integracion externa retorna un tipo inesperado.
  // DOCUMENTACION: https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/Array/isArray
  const payload = await getTrending();
  trending = Array.isArray(payload) ? payload : [];
} catch (err) {
  error = err;
  trending = [];
}
---

<Layout title="Trending">
  <section class="space-y-6">
    <div class="space-y-1">
      <h1 class="text-3xl font-bold text-white tracking-tight">Trending Now</h1>
      <p class="text-gray-400 text-sm">
        A curated snapshot of what's hot across all media.
      </p>
    </div>

    {
      error && (
        <div class="rounded-xl border border-red-500/30 bg-red-500/10 px-4 py-3 text-red-400 text-sm">
          Could not reach the API. Make sure{" "}
          <code class="font-mono">apps/api</code> is running on port 3000.
        </div>
      )
    }

    {
      Array.isArray(trending) && trending.length > 0 && (
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
          {trending.map((item) => (
            <MediaCard
              client:visible
              title={item.title}
              type={item.type}
              image={item.image}
            />
          ))}
        </div>
      )
    }
  </section>
</Layout>
