---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import HomePage from "../components/home/HomePage.tsx";
import MediaCard from "../components/shared/MediaCard.jsx";
import RecommendedUsersWidget from "../components/shared/RecommendedUsersWidget";
import { serverApi } from "../lib/server-api";
import { getRecentPosts } from "../lib/homeData";
import type { RecentPost, TrendingItem } from "../types/home";
import type { Game } from "../types/game";
import type { Movie } from "../types/movie";

// Tipo local para normalizar canciones en tendencia (concepto: adaptador de datos).
type TrendingTrack = {
  id: string;
  title: string;
  artist?: string;
  cover?: string | null;
  previewUrl?: string | null;
  genre?: string;
};

let trending: TrendingItem[] = [];
let errorMessage: string | null = null;
let featuredGames: Game[] = [];
let featuredMovies: Movie[] = [];
let gamesError: string | null = null;
let moviesError: string | null = null;

// Consulta SSR para poblar tendencias (concepto: data fetching en Astro).
try {
  const response = await serverApi.api.music.trending.songs.get();
  if (response.error) throw new Error("API error");
  const payload = response.data as { results?: TrendingTrack[] } | null;
  const results = Array.isArray(payload?.results) ? payload.results : [];
  // Normalizo datos de musica para la UI (concepto: mapeo de DTOs).
  trending = results
    .map<TrendingItem>((track) => ({
      id: String(track.id ?? ""),
      title: track.title ?? "Sin titulo",
      artist: track.artist ?? "Artista desconocido",
      cover: track.cover ?? null,
      previewUrl: track.previewUrl ?? null,
      genre: track.genre ?? undefined,
      type: "music",
    }))
    .filter((item) => item.id);
} catch (err) {
  errorMessage = "No se pudo conectar con el API de tendencias.";
  trending = [];
}

// Consulta SSR para juegos destacados (concepto: carga inicial en servidor).
try {
  const { data, error } = await serverApi.api.games.get();
  if (error)
    throw new Error(
      typeof error.value === "string" ? error.value : "API no disponible",
    );
  // Normalizo respuesta paginada o lista plana (concepto: compatibilidad de payloads).
  const gamesPayload = Array.isArray(data)
    ? (data as Game[])
    : ((data as { items?: Game[] } | null)?.items ?? []);
  featuredGames = gamesPayload.slice(0, 6);
} catch (err) {
  gamesError =
    err instanceof Error ? err.message : "No se pudieron cargar los juegos";
  featuredGames = [];
}

// Consulta SSR para peliculas destacadas (concepto: carga inicial en servidor).
try {
  const { data, error } = await serverApi.api.movies.get();
  if (error)
    throw new Error(
      typeof error.value === "string" ? error.value : "API no disponible",
    );
  // Normalizo respuesta paginada o lista plana (concepto: compatibilidad de payloads).
  const moviesPayload = Array.isArray(data)
    ? (data as Movie[])
    : ((data as { items?: Movie[] } | null)?.items ?? []);
  featuredMovies = moviesPayload.slice(0, 6);
} catch (err) {
  moviesError =
    err instanceof Error ? err.message : "No se pudieron cargar las peliculas";
  featuredMovies = [];
}

// Datos del feed desde capa dedicada.
// ESTADO: mock por ahora; alimenta Circles, SocialPulse, LiveRooms y Feed.
// FALTA: endpoint real de actividad social o posts persistentes.
const recentPosts: RecentPost[] = getRecentPosts();
---

<Layout title="Inicio">
  <!-- Metadato especifico por pagina usando slot nombrado (concepto: slots en Astro). -->
  <meta
    slot="head"
    name="description"
    content="Alexandria inicio con feed social y tendencias activas."
  />

  <!-- Home React hidratada para animaciones (concepto: islands con client:load). -->
  <HomePage
    client:load
    trending={trending}
    recentPosts={recentPosts}
    errorMessage={errorMessage}
    games={featuredGames}
    movies={featuredMovies}
    gamesError={gamesError}
    moviesError={moviesError}
  />
</Layout>
