---
import Layout from "../../layouts/Layout.astro";
import GameDetailsClient from "../../components/games/GameDetailsClient";
import { serverApi } from "../../lib/server-api";
import { Icon } from "@iconify/react";
import type { Game } from "../../types/game";

// CONCEPTO: Caché HTTP SSR en Rutas Dinámicas
// QUE HACE: Guarda el HTML generado del detalle del juego en memoria temporalmente.
// POR QUE LO USO: Hace que la View Transition al entrar al juego sea totalmente instantánea.
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=60, stale-while-revalidate=120",
);

// CONCEPTO: Rutas Dinamicas con Astro.params
// QUE HACE: Lee el parametro [id] de la URL para resolver el juego solicitado.
// POR QUE LO USO: Permite generar una sola plantilla reutilizable para todos los detalles de juegos.
const { id } = Astro.params;

let game: Game | null = null;
let errorMessage = "";

try {
  // CONCEPTO: Guard Clause de Parametro
  // QUE HACE: Detiene la ejecucion si falta el id en la ruta.
  // POR QUE LO USO: Evita consultas invalidas y facilita mostrar un mensaje claro al usuario.
  if (!id) {
    throw new Error("ID de juego no proporcionado");
  }

  // CONCEPTO: Carga de Datos en SSR
  // QUE HACE: Recupera en servidor el detalle del juego antes de renderizar la pagina.
  // POR QUE LO USO: Mejora SEO y evita pantallas vacias al primer render.
  const { data, error } = await serverApi.api.games({ apiId: id }).get();
  if (error)
    throw new Error(
      typeof error.value === "string" ? error.value : "API no disponible",
    );
  game = data as Game;
} catch (error) {
  errorMessage =
    error instanceof Error
      ? error.message
      : "Ocurrio un error al cargar los detalles del juego";
}
---

<Layout
  title={game ? `${game.title} - Detalles | Alexandria` : "Error | Alexandria"}
>
  <div class="mb-6">
    <a
      href="/games"
      class="inline-flex items-center gap-2 text-sm text-slate dark:text-mist hover:text-ink dark:hover:text-screen transition-colors group"
    >
      <Icon
        icon="tabler:arrow-left"
        className="w-5 h-5 group-hover:-translate-x-0.5 transition-transform"
      />
      Volver a Videojuegos
    </a>
  </div>
  {
    errorMessage || !game ? (
      <div class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4">
        <div class="rounded-2xl border border-bone dark:border-night-edge bg-linen dark:bg-coal p-8 max-w-md w-full shadow-lg">
          <Icon
            icon="tabler:device-gamepad-2"
            className="mx-auto mb-4 h-16 w-16 text-slate opacity-50 dark:text-mist"
          />
          <h1 class="mb-2 text-2xl font-bold text-ink dark:text-screen">
            Juego no encontrado
          </h1>
          <p class="mb-6 text-sm text-slate dark:text-mist">
            {errorMessage ||
              "No hemos podido encontrar los detalles de este juego. Puede que el enlace sea incorrecto o el servicio no esté disponible."}
          </p>
          <a
            href="/games"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-ink px-5 py-3 text-sm font-semibold text-screen transition-all hover:scale-105 active:scale-95 dark:bg-screen dark:text-ink"
          >
            Volver al catálogo
          </a>
        </div>
      </div>
    ) : (
      // CONCEPTO: Hidratacion de Isla React
      // QUE HACE: Activa comportamiento interactivo del detalle (botones, comentarios, etc.).
      // POR QUE LO USO: Mantiene el render inicial en SSR y la interactividad en cliente.
      <GameDetailsClient client:load game={game} />
    )
  }
</Layout>
