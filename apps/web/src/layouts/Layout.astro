---
// src/layouts/Layout.astro
import "../styles/global.css";
import NavBar from "../components/navbar/NavBar.astro";
import FooterPlayer from "../components/music/FooterPlayer.jsx";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
}

const { title = "Alexandria" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Alexandria — Your cross-media social catalog"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · Alexandria</title>
    <script is:inline>
      // Blocking theme init — runs before paint to avoid FOUC
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet" />
  </head>
  <body class="min-h-screen font-sans">
    <NavBar />

    <main class="max-w-6xl mx-auto px-4 py-10 pb-28">
      <slot />
    </main>

    <FooterPlayer client:only="react" transition:persist />
  </body>
</html>


