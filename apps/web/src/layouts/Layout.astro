---
// src/layouts/Layout.astro
import "../styles/global.css";
import NavBar from "../components/navbar/NavBar.astro";
import FooterPlayer from "../components/music/FooterPlayer.jsx";
import ChatButton from "../components/chat/ChatButton.tsx";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
}

const { title = "Alexandria" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Alexandria — Tu catálogo social multiplataforma para cine, música y videojuegos."
    />
    <meta name="theme-color" content="#09090b" />
    <meta property="og:title" content={`${title} · Alexandria`} />
    <meta
      property="og:description"
      content="Tu universo cultural empieza aquí. Catálogo social de cine, juegos y música."
    />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · Alexandria</title>
    <!-- Slot nombrado para metadatos por pagina (concepto: slots en Astro). -->
    <slot name="head" />
    <script is:inline>
      // Blocking theme init — runs before paint to avoid FOUC
      (function () {
        var stored = localStorage.getItem("theme");
        var prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen font-sans">
    <NavBar />

    <main
      class="mx-auto w-full max-w-[1440px] px-4 py-8 pb-28 sm:px-6 lg:px-8 lg:py-10"
    >
      <slot />
    </main>

    <FooterPlayer client:only="react" transition:persist />
    <ChatButton client:only="react" transition:persist />
  </body>
</html>
