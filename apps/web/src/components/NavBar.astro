---
import SearchBar from "./SearchBar.jsx";

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/movies", label: "Movies", icon: "🎬" },
  { href: "/music", label: "Music", icon: "🎵" },
  { href: "/games", label: "Games", icon: "🎮" },
  { href: "/groups", label: "Groups", icon: "👥" },
];
---

<header
  id="main-navbar"
  class="sticky top-0 z-50 border-b border-white/[0.07] bg-zinc-950/80 backdrop-blur-xl shadow-[0_1px_24px_rgba(0,0,0,0.4)]"
>
  <!-- Fila de escritorio -->
  <div class="mx-auto flex h-16 max-w-7xl items-center gap-5 px-5">
    <!-- Logotipo -->
    <a
      href="/"
      aria-label="Alexandria home"
      class="flex shrink-0 items-center gap-2 no-underline opacity-100 transition-opacity duration-200 hover:opacity-85"
    >
      <span class="text-[1.4rem] leading-none">📚</span>
      <span class="text-[1.1rem] font-bold tracking-tight text-white">Alexandria</span>
      <span
        class="rounded-full border border-indigo-400/25 bg-indigo-400/[0.12] px-[0.45rem] py-[0.1rem] text-[0.65rem] font-semibold leading-[1.6] text-indigo-400"
      >
        TFG
      </span>
    </a>

    <!-- Barra de búsqueda -->
    <SearchBar client:load />

    <!-- Enlaces de navegación (escritorio) -->
    <nav
      class="hidden md:flex shrink-0 items-center gap-1"
      aria-label="Main navigation"
    >
      {
        navLinks.map(({ href, label, icon }) => {
          const isActive = currentPath.startsWith(href);
          return (
            <a
              href={href}
              aria-current={isActive ? "page" : undefined}
              class={[
                "flex items-center gap-[0.4rem] rounded-lg px-[0.85rem] py-[0.45rem] text-sm font-medium no-underline whitespace-nowrap transition-[color,background] duration-[180ms]",
                isActive
                  ? "bg-indigo-500/[0.12] text-indigo-300 hover:bg-indigo-500/[0.18] hover:text-indigo-200"
                  : "text-gray-400 hover:bg-white/[0.06] hover:text-white",
              ].join(" ")}
            >
              <span aria-hidden="true" class="text-base leading-none">
                {icon}
              </span>
              <span class="hidden lg:inline leading-none">{label}</span>
            </a>
          );
        })
      }
    </nav>

    <!-- Icono de perfil (escritorio) -->
    <a
      href="/profile"
      id="profile-btn"
      aria-label="Go to profile"
      class="hidden md:flex shrink-0 items-center justify-center w-[38px] h-[38px] rounded-full border border-white/[0.08] bg-white/[0.04] text-gray-400 no-underline transition-[color,background,border-color,transform] duration-[180ms] hover:border-indigo-500/40 hover:bg-indigo-500/[0.15] hover:text-white hover:scale-[1.08]"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="8" r="4"></circle>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"></path>
      </svg>
    </a>

    <!-- Menú hamburguesa móvil -->
    <button
      id="mobile-menu-btn"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      class="md:hidden ml-auto flex shrink-0 flex-col items-center justify-center gap-[4px] w-[38px] h-[38px] rounded-lg border border-white/[0.08] bg-transparent p-[0.55rem] cursor-pointer transition-[background] duration-[180ms] hover:bg-white/[0.07]"
    >
      <span
        class="block w-full h-[2px] rounded-sm bg-gray-400 transition-[transform,opacity] duration-200"
      ></span>
      <span
        class="block w-full h-[2px] rounded-sm bg-gray-400 transition-[transform,opacity] duration-200"
      ></span>
      <span
        class="block w-full h-[2px] rounded-sm bg-gray-400 transition-[transform,opacity] duration-200"
      ></span>
    </button>
  </div>

  <!-- Cajón móvil (oculto por defecto, alternado vía JS) -->
  <div
    id="mobile-drawer"
    aria-hidden="true"
    class="hidden flex-col gap-2 border-t border-white/[0.06] bg-zinc-950/[0.96] px-5 pt-3 pb-4 md:hidden"
  >

    <!-- Enlaces de navegación móviles -->
    <nav class="flex flex-col gap-[0.1rem]" aria-label="Mobile navigation">
      {
        navLinks.map(({ href, label, icon }) => {
          const isActive = currentPath.startsWith(href);
          return (
            <a
              href={href}
              aria-current={isActive ? "page" : undefined}
              class={[
                "flex items-center gap-[0.6rem] rounded-lg px-3 py-[0.65rem] text-[0.9rem] font-medium no-underline transition-[color,background] duration-150",
                isActive
                  ? "bg-indigo-500/[0.12] text-indigo-300"
                  : "text-gray-400 hover:bg-white/[0.06] hover:text-white",
              ].join(" ")}
            >
              <span aria-hidden="true">{icon}</span> {label}
            </a>
          );
        })
      }
      <a
        href="/profile"
        class="flex items-center gap-[0.6rem] rounded-lg px-3 py-[0.65rem] text-[0.9rem] font-medium text-gray-400 no-underline transition-[color,background] duration-150 hover:bg-white/[0.06] hover:text-white"
      >
        <span aria-hidden="true">👤</span> Profile
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const drawer = document.getElementById("mobile-drawer");

  btn?.addEventListener("click", () => {
    const isOpen = drawer?.classList.toggle("hidden") === false;
    drawer?.classList.toggle("flex", isOpen);
    btn.setAttribute("aria-expanded", String(isOpen));
    drawer?.setAttribute("aria-hidden", String(!isOpen));
  });
</script>
